{
  "name": "@supercharge/promise-pool",
  "description": "Map-like, concurrent promise processing for Node.js",
  "version": "4.0.0",
  "authors": ["Marcus Pöhls <marcus@superchargejs.com>", "Daniel Maricic <daniel@woss.io>"],
  "bugs": {
    "url": "https://github.com/superchargejs/promise-pool/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.4",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "3.2.4",
    "husky": "^9.1.7",
    "typescript": "~5.9.2",
    "vitest": "~3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://github.com/superchargejs/promise-pool",
  "keywords": [
    "supercharge",
    "superchargejs",
    "promise-pool",
    "nodejs",
    "async",
    "map",
    "async-map",
    "promises"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./promise-pool-executor": {
      "import": "./dist/promise-pool-executor.js",
      "types": "./dist/promise-pool-executor.d.ts"
    },
    "./promise-pool-error": {
      "import": "./dist/promise-pool-error.js",
      "types": "./dist/promise-pool-error.d.ts"
    },
    "./validation-error": {
      "import": "./dist/validation-error.js",
      "types": "./dist/validation-error.d.ts"
    }
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/superchargejs/promise-pool.git"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "biome check .",
    "lint:fix": "biome check . --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "biome format .",
    "prepare": "husky"
  },
  "sideEffects": false,
  "types": "dist",
  "packageManager": "pnpm@10.5.2"
}
